# ===== Application Configuration =====
APP_ENV=production
LOG_LEVEL=INFO
RAW_DATA_FILE=

# ===== Vector Database (Qdrant) =====
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=nmk_chatbot_collection
QDRANT_TIMEOUT=30

# ===== Embedding Model =====
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=64

# ===== LLM Configuration =====
# Supported providers: huggingface_local | ollama
LLM_PROVIDER=huggingface_local
LLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
LLM_BASE_URL=http://localhost:11434
LLM_DEVICE=cpu
LLM_TRUST_REMOTE_CODE=false
LLM_LOAD_IN_8BIT=false
LLM_ENABLE_FALLBACK=false
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=384
LLM_TIMEOUT=180

# ===== Retrieval Configuration =====
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.3
DENSE_WEIGHT=0.6
BM25_WEIGHT=0.4

# ===== Reranking Configuration =====
RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKING_DEVICE=cpu
RERANKING_TOP_K=5

# ===== Security =====
MAX_QUERY_LENGTH=500
RATE_LIMIT_PER_MINUTE=60
DEMO_RATE_LIMIT_ENABLED=false
MAX_RETRIEVAL_TOP_K=20
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
